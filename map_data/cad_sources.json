    { "pdf": "3F-A.pdf", "zone": "A", "floors": [3], "outputs": ["plans/f3_a_cad.png"] },
    { "pdf": "4F-A.pdf", "zone": "A", "floors": [4], "outputs": ["plans/f4_a_cad.png"] },
    { "pdf": "5F-A.pdf", "zone": "A", "floors": [5], "outputs": ["plans/f5_a_cad.png"] },
    {
      "pdf": "1_2_5F-B.pdf",
      "zone": "B",
      "floors": [1, 2, 5],
      "rotateCw": 90,
      "note": "原图上方为东，导出时顺时针90°使北向上",
